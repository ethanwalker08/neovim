{
  "workbench.colorTheme": "Atom One Dark",
  "editor.semanticHighlighting.enabled": true,
  "editor.stickyScroll.enabled": false,
  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.fontLigatures": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.suggest.enabled": true,
  "svelte.plugin.svelte.defaultScriptLanguage": "ts",
  "svelte.enable-ts-plugin": true,
  "git.confirmSync": false,
  "git.autofetch": "all",
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  "workbench.startupEditor": "none",
  "vsicons.dontShowNewVersionMessage": true,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],
  "remote.portsAttributes": {
    "54321": {
      "protocol": "http"
    }
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "update.showReleaseNotes": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "chat.mcp.autostart": "onlyNew",
  "vscode-neovim.neovimExecutablePaths.win32": "C:\\Program Files\\Neovim\\bin\\nvim.exe",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vscode-neovim.ctrlKeysForInsertMode": [],
  "vscode-neovim.compositeTimeout": 400,
  "vscode-neovim.logOutputToConsole": false,
  "workbench.list.typeNavigationMode": "automatic",
  "editor.renderWhitespace": "none",
  "editor.guides.indentation": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.selectionHighlight": true,
  "chat.tools.terminal.autoApprove": {
    "New-Item": true,
    "flutter": true
  },
  "chat.mcp.gallery.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "dart.analysisServerFolding": false,
  "dart.analyzeAngularTemplates": false,
  "dart.checkForSdkUpdates": false,
  "dart.devToolsBrowser": "default",
  "dart.documentation": "summary",
  "dart.hotReloadProgress": "statusBar",
  "dart.inlayHints": true,
  "dart.normalizeFileCasing": true,
  "dart.previewFlutterUiGuides": true,
  "dart.previewFlutterUiGuidesCustomTracking": true,
  "dart.previewHotReloadOnSaveWatcher": true,
  "dart.projectSearchDepth": 2,
  "dart.promptToRunIfErrors": false,
  "dart.renameFilesWithClasses": "always",
  "dart.runPubGetOnPubspecChanges": "prompt",
  "dart.showDartPadSampleCodeLens": false,
  "dart.showDebuggerNumbersAsHex": true,
  "dart.showInspectorNotificationsForWidgetErrors": false,
  "dart.showSkippedTests": false,
  "dart.showTodos": [
    "TODO",
    "FIXME",
    "WARN",
    "NOTE",
    "ERROR",
    "WARNING"
  ],
  "dart.suppressTestTimeouts": "always",
  "dart.updateDevTools": false,
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.flutter",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.mouseWheelZoom": true,
    "editor.tabSize": 2,
    "editor.detectIndentation": true,
    "files.autoSave": "off",
    "editor.accessibilitySupport": "off"
  },
  "zenMode.fullScreen": false,
  "zenMode.centerLayout": false,
  "zenMode.hideActivityBar": false,
  "zenMode.hideStatusBar": false,
  "zenMode.restore": false,
  "window.autoDetectHighContrast": false,
  "chat.tools.global.autoApprove": true,
  "pgsql.enableQueryHistoryCapture": false,
  "todo-tree.general.automaticGitRefreshInterval": 10,
  "todo-tree.general.periodicRefreshInterval": 3,
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "TODO",
    "NOTE",
    "WARN",
    "WARNING",
    "DEBUG",
  ],
  "todo-tree.highlights.useColourScheme": true,
  "todo-tree.highlights.customHighlight": {
    "BUG": {
      "foreground": "#ececec",
      "background": "#ff0000",
      "opacity": 75,
      "icon": "bug"
    },
    "HACK": {
      "foreground": "#000000",
      "background": "#ff48",
      "opacity": 65
    },
    "FIXME": {
      "background": "#ffc400",
      "foreground": "#000000",
      "opacity": 0
    },
    "TODO": {
      "foreground": "#ececec",
      "background": "#38c957",
      "opacity": 80
    },
    "NOTE": {
      "icon": "info",
      "foreground": "#FFFFFF",
      "background": "#ac72bd",
      "opacity": 70
    },
    "DEBUG": {
      "icon": "bug",
      "foreground": "#FFFFFF",
      "background": "#ac72bd",
      "opacity": 70,
      "gutterIcon": true,
      "iconColour": "#ac72bd",
    },
    "WARN": {
      "icon": "info",
      "foreground": "#FFFFFF",
      "background": "#ac72bd",
      "opacity": 70
    },
  },
  "vscode-neovim.ctrlKeysForNormalMode": [],
  "vscode-neovim.neovimViewportHeightExtend": 3,
  "chat.useAgentSkills": true,
  "[dockercompose]": {
    "editor.defaultFormatter": "docker.docker"
  },
  "python-envs.defaultPackageManager": "ms-python.python:uv",
  "python.terminal.useEnvFile": true,
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "ruff.configurationPreference": "filesystemFirst",
  "python.missingPackage.severity": "Error",
  "github.copilot.selectedCompletionModel": "",
  "github.copilot.chat.useResponsesApi": false,
  "terminal.external.windowsExec": "C:\\Users\\YourUser\\AppData\\Local\\Microsoft\\WindowsApps\\wt.exe",
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[sql]": {
    "editor.defaultFormatter": "ms-ossdata.vscode-pgsql"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "terminal.integrated.confirmOnKill": "always",
  "terminal.integrated.localEchoExcludePrograms": [
    "vim",
    "vi",
    "nano",
    "tmux",
    "nvim"
  ],
  "terminal.integrated.suggest.quickSuggestions": {
    "arguments": "on",
    "commands": "on"
  },
  "editor.minimap.enabled": false,
  "workbench.iconTheme": "vscode-icons",
  "workbench.editor.enablePreview": false,
  "chat.agent.maxRequests": 100
}
